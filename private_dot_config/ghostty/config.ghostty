# --- Theme ---
config-file = ?auto/theme.ghostty

# --- Fonts ---
font-family = "JetBrains Mono"
font-size = 13

# --- Cursor ---
cursor-style = block

# --- Window ---
window-height = 38
window-width = 120

# --- Mouse ---
mouse-hide-while-typing = true

# --- Terminal & Shell ---
command = /bin/fish -l

# --- Keybinds ---
keybind = f11=toggle_fullscreen
keybind = ctrl+shift+t=new_window
keybind = alt+]=new_split:right
keybind = alt+[=new_split:down

